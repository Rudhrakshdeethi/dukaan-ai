# ---- Copy this file to ".env" and fill in the values ----

# 1) Telegram bot token (FREE, 2 min): open @BotFather in Telegram → /newbot → paste token here.
TELEGRAM_BOT_TOKEN=

# 2) Gemini API key (FREE tier): https://aistudio.google.com/apikey
#    Without this the bot still runs in rule-based mode (no photo OCR / voice / NL queries).
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# 3) Dashboard port (optional)
PORT=3000

# Store display name shown on the dashboard (optional)
STORE_NAME=Sri Lakshmi Kirana

# ---- Production hardening (all optional; unset = open, convenient for demos) ----
# Make the bot private: only these Telegram chat/user IDs may control the shop.
TELEGRAM_OWNER_IDS=
# Require this token (x-admin-token header) to call POST /api/seed (reset data).
ADMIN_TOKEN=

# ---- Bot run mode ----
# Leave PUBLIC_URL empty for local dev (long-polling). In production, set it to your
# public HTTPS base URL (e.g. https://dukaan-ai.onrender.com) to run in WEBHOOK mode.
# On Render this is auto-detected via RENDER_EXTERNAL_URL — you don't need to set it.
PUBLIC_URL=
# Optional shared secret to authenticate Telegram's webhook POSTs (recommended in prod).
TELEGRAM_WEBHOOK_SECRET=

# ---- WhatsApp (optional, post-hackathon — needs Meta business verification) ----
WHATSAPP_TOKEN=
WHATSAPP_PHONE_ID=
WHATSAPP_VERIFY_TOKEN=takeover26
